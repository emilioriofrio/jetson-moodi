/integradora/**/*.py[co]
/integradora/**/*.zip
/integradora/model_ia/detectron2/build/
/integradora/model_ia/detectron2/dist/
/integradora/model_ia/detectron2/detectron2.egg-info/

# 2. Inside apps/
/apps/llm/llama.cpp/
/apps/**/__pycache__/

# 3. Inside yahboom_ws/
/yahboom_ws/build/
/yahboom_ws/install/
/yahboom_ws/log/
