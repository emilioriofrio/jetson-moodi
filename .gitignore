# Ignore everything in the root directory by default
/*

# Whitelist project files in the root directory
!/.gitignore
!/PROGRESO_BMO.md
!/install_env.sh
!/requirements_x86.txt
!/mod_a.py

# Whitelist project folders
!/integradora/
!/apps/
!/qr_code_recognition/
!/yahboom_ws/
!/bmo_unified/

# Ignore specific large files/folders inside whitelisted directories

# 1. Inside integradora/
/integradora/model_ia/pruebas_mod/
/integradora/model_ia/moduloC_dataset/vectores_numpy/resultados_entrenamiento/bilstm_mejor_modelo.pth
/integradora/Oraciones_interpret/.pio/
/integradora/Oraciones_interpret/.vscode/
